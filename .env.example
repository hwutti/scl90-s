# Kopieren nach .env und Werte anpassen

# PostgreSQL
DATABASE_URL="postgresql://scl90s_user:PASSWORT@localhost:5432/scl90s_db?schema=public"

# NextAuth (generieren: openssl rand -base64 48)
NEXTAUTH_SECRET="HIER_ZUFAELLIGES_SECRET_EINTRAGEN"
NEXTAUTH_URL="https://DEINE_DOMAIN.AT"

# App
NODE_ENV="production"
APP_PORT="3000"

# Verschlüsselung (generieren: openssl rand -hex 32)
ENCRYPTION_KEY="HIER_64_ZEICHEN_HEX_KEY_EINTRAGEN"
