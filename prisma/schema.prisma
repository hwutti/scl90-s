generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  THERAPIST
  PATIENT
}

enum Gender {
  MALE
  FEMALE
  DIVERSE
}

enum AssessmentStatus {
  ASSIGNED    // Therapeut hat angelegt, Patient noch nicht gestartet
  IN_PROGRESS // Patient hat begonnen
  COMPLETED   // Alle Items beantwortet
  SCORED      // Auswertung berechnet
  LOCKED      // Gesperrt (archiviert)
}

enum NoteType {
  PROGRESS    // Verlaufsnotiz (§16a)
  ANAMNESIS   // Anamnesegespräch
  GOAL        // Therapieziel
  INTERVENTION
  OTHER
}

enum NormPopulation {
  GENERAL_POPULATION
  STUDENTS
  CLINICAL_INPATIENT
  CLINICAL_REHAB
  CUSTOM
}

enum AuditAction {
  PATIENT_CREATED
  PATIENT_UPDATED
  PATIENT_VIEWED
  PATIENT_DELETED
  RECORD_UPDATED
  ASSESSMENT_CREATED
  ASSESSMENT_STARTED
  ASSESSMENT_COMPLETED
  ASSESSMENT_SCORED
  ASSESSMENT_VIEWED
  ASSESSMENT_EXPORTED
  ASSESSMENT_DELETED
  NOTE_CREATED
  NOTE_UPDATED
  NOTE_DELETED
  USER_CREATED
  USER_UPDATED
  USER_LOGIN
  USER_LOGOUT
  DATA_DELETED
  BACKUP_CREATED
  FINANCE_DATA_EXPORTED
  DUNNING_SENT
  MIGRATION_IMPORT
  MIGRATION_IMPORTED
  APPOINTMENT_CREATED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_NO_SHOW
  APPOINTMENT_COMPLETED
  DOCUMENT_UPLOADED
  DOCUMENT_DELETED
  DOCUMENT_VIEWED
  DIAGNOSIS_CREATED
  DIAGNOSIS_UPDATED
  DIAGNOSIS_DELETED
  GOAL_CREATED
  GOAL_UPDATED
  FINANCE_CREATED
  FINANCE_UPDATED
  FINANCE_DELETED
  MILEAGE_CREATED
  MILEAGE_DELETED
  EMAIL_SENT
}


// ─── Session & Protokoll ──────────────────────────────────────────────────────

enum SessionBillingStatus {
  EXCLUDED      // explizit von Finanzen ausgeschlossen
  UNBILLED      // keine aktive Allocation
  BILLED_UNPAID // min. eine Allocation, aber Transaktion offen
  PAID          // alle Transaktionen bezahlt
}

enum ProtocolType {
  SHORT  // Kurzprotokoll (§16a, patientenzugänglich)
  LONG   // Langprotokoll (persönlich, restriktiv)
}

enum SessionSource {
  MANUAL      // manuell erstellt
  APPOINTMENT // aus Kalendertermin
}

// ─── Finanzen (neu, vollständig nach Spezifikation) ──────────────────────────

enum TxDirection {
  INCOME
  EXPENSE
}

enum TxSourceType {
  SESSION
  MANUAL
  TRAVEL
  CANCELLATION
  CORRECTION
}

enum TxLifecycleStatus {
  ACTIVE
  UNDONE
  CANCELLED_ORIGINAL
  CANCELLATION_TX
}

enum TxPaymentStatus {
  UNPAID
  PAID
}

enum DunningLevel {
  ERINNERUNG
  MAHNUNG_1
  MAHNUNG_2
}

enum TxPaymentMethod {
  UNBAR_BANK_TRANSFER
  CASH
  CASH_HELLOCASH
  CARD_BANKOMAT
  UNKNOWN
}

enum InvoiceDocumentType {
  INVOICE_PDF
  INVOICE_XLSX
  RECEIPT_PDF
  CANCELLATION_INVOICE
  EXTERNAL_VOUCHER
}

// ─── Screening (erweiterbar) ──────────────────────────────────────────────────

enum ScreeningStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  SCORED
  LOCKED
}

// ─── VideoCall ────────────────────────────────────────────────────────────────

enum VideoCallStatus {
  PLANNED
  ACTIVE
  ENDED
  EXPIRED
  CANCELLED
}

// ─── Google Calendar ──────────────────────────────────────────────────────────

enum GoogleSyncStatus {
  ACTIVE
  PAUSED
  ERROR
  DISCONNECTED
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  name         String?
  role         Role      @default(PATIENT)
  passwordHash String?
  pin          String?   @unique
  avatarBase64 String?   // Profilbild als Base64
  avatarMime   String?   // MIME-Typ des Profilbilds
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Therapeut-Patient Hierarchie (für User-basierte Zuordnung, bleibt für Admin/Therapeut)
  therapistId  String?
  therapist    User?     @relation("TherapistUsers", fields: [therapistId], references: [id])
  subordinates User[]    @relation("TherapistUsers")

  // Relationen
  createdPatients   Patient[]          @relation("CreatedByUser")
  patientProfile    Patient?           @relation("PatientUser")
  therapistPatients TherapistPatient[] @relation("TherapistRelation")
  createdAssessments Assessment[]      @relation("AssessmentCreator")
  sessionNotes      SessionNote[]      @relation("NoteAuthor")
  auditLogs         AuditLog[]
  nextAuthSessions  NextAuthSession[]
  accounts          Account[]

  // Kalender-Relationen
  therapistAppointments Appointment[]       @relation("TherapistAppointments")
  therapistAvailability AvailabilitySlot[]  @relation("TherapistAvailability")
  therapistAbsences     Absence[]           @relation("TherapistAbsences")
  therapistWaitlist     WaitlistEntry[]     @relation("TherapistWaitlist")
  appointmentTypes      AppointmentType[]   @relation("TherapistAppointmentTypes")
  notifications         Notification[]      @relation("UserNotifications")
  notificationSetting   NotificationSetting?

  // Neue KDS-Relationen
  therapySessions       TherapySession[]        @relation("TherapistSessions")
  userTransactions      Transaction[]           @relation("UserTransactions")
  googleCalendar        GoogleCalendarConnection? @relation("UserGoogleCalendar")
  patientSharesOwned    PatientShare[] @relation("OwnerUser")
  patientSharesReceived PatientShare[] @relation("SharedWithUser")
  videoCalls            VideoCall[]             @relation("UserVideoCalls")
  exportJobs            ExportJob[]             @relation("UserExportJobs")
  supervisionEntriesAs  SupervisionEntry[]      @relation("SuperviseeEntries")
  supervisorEntries     SupervisionEntry[]      @relation("SupervisorEntries")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model NextAuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── Kern: Patient ────────────────────────────────────────────────────────────

model Patient {
  id              String    @id @default(cuid())

  // Stammdaten
  firstName       String
  lastName        String
  dob             String    // YYYY-MM-DD
  gender          Gender
  svnr            String?   // Sozialversicherungsnummer (optional, verschlüsselt)
  phone           String?
  email           String?
  insuranceProvider String? // Versicherungsträger
  referralSource  String?   // Zuweiser / Zuweisung durch

  // Rechnungsempfänger (KDS-SCR-06A)
  billRecipientName    String?   // anderer Rechnungsempfänger Name
  billRecipientAddress String?   // Adresszeile 1
  billRecipientCity    String?   // PLZ + Stadt

  // Abrechnungs-Einstellungen pro Profil (KDS-SCR-06A)
  defaultBillingMode     String?   @default("time")  // "time" | "unit"
  defaultUnitDuration    Int?      @default(50)       // Minuten pro Einheit
  defaultUnitPriceNet    Decimal?  @db.Decimal(10,2)  // Kosten pro Einheit
  defaultHourlyRateNet   Decimal?  @db.Decimal(10,2)  // Stundensatz
  defaultInvoiceTemplateId String?
  sharedWith    PatientShare[] @relation("PatientShares")
  defaultInvoiceTemplate   InvoiceTemplate? @relation("PatientInvoiceTemplate", fields: [defaultInvoiceTemplateId], references: [id])
  defaultVatRate         Decimal?  @db.Decimal(5,4) @default(0)    // Standard-MwSt. 0=0%, 0.1=10%, 0.2=20%
  defaultPaymentMethod   String?   @default("UNBAR_BANK_TRANSFER")  // CASH | CARD_BANKOMAT | UNBAR_BANK_TRANSFER
  defaultMarkAsPaid      Boolean   @default(false)                   // sofort als bezahlt markieren?
  sessionStartNumber     Int       @default(0)        // Startzahl für Sessionzähler

  // Beziehungen zu Users
  createdByUserId String
  createdBy       User      @relation("CreatedByUser", fields: [createdByUserId], references: [id])

  patientUserId   String?   @unique  // falls Patient selbst einen Login hat (PIN)
  patientUser     User?     @relation("PatientUser", fields: [patientUserId], references: [id])

  // Anonymisierung
  codeName        String?   // z.B. "KL-001" für anonymisierten Export
  codeNameAuto    Boolean   @default(true)  // automatisch generiert

  // Status
  active          Boolean   @default(true)
  deletedAt       DateTime? // soft delete (Aufbewahrungspflicht 10 Jahre §16a)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relationen
  therapists      TherapistPatient[]
  record          PatientRecord?
  assessments     Assessment[]
  sessionNotes    SessionNote[]
  auditLogs       AuditLog[]
  appointments    Appointment[]
  waitlistEntries WaitlistEntry[]
  photo           PatientPhoto?
  documents       PatientDocument[]
  therapyGoals    TherapyGoal[]
  diagnoses       PatientDiagnosis[]
  transactions    FinanceTransaction[]
  mileageLogs     MileageLog[]

  // Neue KDS-Relationen
  therapySessions       TherapySession[]        @relation("PatientSessions")
  txTransactions        Transaction[]           @relation("PatientTransactions")
  anamnesis             Anamnesis?              @relation("PatientAnamnesis")
  medications           Medication[]            @relation("PatientMedications")
  contingents           ContingentAccount[]     @relation("PatientContingents")
  timelineEvents        ProfileTimelineEvent[]  @relation("PatientTimeline")
  travelLogs            TravelLogEntry[]        @relation("PatientTravelLog")
  videoCalls            VideoCall[]             @relation("PatientVideoCalls")
  ratings               SessionRating[]         @relation("PatientRatings")
  audioRecordings       AudioRecording[]        @relation("PatientAudio")
  reportDocuments       PatientReportDocument[]
  confirmations         Confirmation[]

  @@index([lastName, firstName])
  @@index([dob])
}

// Therapeut ↔ Patient (many-to-many, ein Patient kann mehrere Behandler haben)
model TherapistPatient {
  id               String    @id @default(cuid())
  therapistId      String
  therapist        User      @relation("TherapistRelation", fields: [therapistId], references: [id])
  patientId        String
  patient          Patient   @relation(fields: [patientId], references: [id])
  isPrimary        Boolean   @default(true)
  since            DateTime  @default(now())
  until            DateTime?
  createdAt        DateTime  @default(now())

  @@unique([therapistId, patientId])
  @@index([therapistId])
  @@index([patientId])
}

// ─── Patientenakte (klinischer Inhalt) ───────────────────────────────────────

model PatientRecord {
  id              String    @id @default(cuid())
  patientId       String    @unique
  patient         Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Anamnese
  chiefComplaint  String?   // Hauptbeschwerde
  medicalHistory  String?   // Psychiatrische/medizinische Vorgeschichte
  medication      String?   // Aktuelle Medikation
  allergies       String?   // Allergien / Unverträglichkeiten
  familyHistory   String?   // Familienanamnese
  socialHistory   String?   // Soziale Anamnese (Beruf, Beziehung, etc.)

  // Diagnosen (ICD-10, als JSON-Array)
  // Format: [{code: "F32.1", label: "Mittelgradige depressive Episode", date: "2024-01-15", isPrimary: true}]
  diagnoses       Json      @default("[]")

  // Therapie
  therapyGoals    String?   // Therapieziele (Freitext)
  therapyStart    DateTime?
  therapyEnd      DateTime?
  sessionFrequency String?  // z.B. "wöchentlich", "14-tägig"

  // Sonstiges
  notes           String?   // Interne Notizen des Therapeuten (nicht für Patient sichtbar)

  // Versionierung (jede Änderung wird protokolliert)
  version         Int       @default(1)
  updatedAt       DateTime  @updatedAt
  updatedByUserId String?
}

// ─── Instrumente (erweiterbar) ───────────────────────────────────────────────

model Instrument {
  id          String       @id @default(cuid())
  code        String       @unique // "SCL90S", "BDI2", "PHQ9", "GAD7", …
  name        String       // "SCL-90-S – Symptom-Checkliste 90 Standard"
  shortName   String       // "SCL-90-S"
  version     String       @default("1.0")
  description String?
  itemCount   Int
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())

  assessments Assessment[]
}

// ─── Assessment (ein Test = eine Erhebung eines Instruments) ─────────────────

model Assessment {
  id              String           @id @default(cuid())
  patientId       String
  patient         Patient          @relation(fields: [patientId], references: [id])
  instrumentId    String
  instrument      Instrument       @relation(fields: [instrumentId], references: [id])
  createdByUserId String
  createdBy       User             @relation("AssessmentCreator", fields: [createdByUserId], references: [id])

  status          AssessmentStatus @default(ASSIGNED)
  occasion        String?          // z.B. "Ersterhebung", "Verlauf Woche 4"

  // Norm-Kontext (wird aus Patientenstammdaten befüllt, kann überschrieben werden)
  normTableId     String?
  normTable       NormTable?       @relation(fields: [normTableId], references: [id])

  // Zeitstempel
  startedAt       DateTime?
  completedAt     DateTime?
  scoredAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  answers         Answer[]
  result          AssessmentResult?
  auditLogs       AuditLog[]
  sessionLinks    SessionAssessmentLink[]

  @@index([patientId])
  @@index([instrumentId])
}

model Answer {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  itemNumber   Int
  value        Int?
  answeredAt   DateTime?

  @@unique([assessmentId, itemNumber])
  @@index([assessmentId])
}

model AssessmentResult {
  id               String     @id @default(cuid())
  assessmentId     String     @unique
  assessment       Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  // Flexibles JSON — jedes Instrument speichert sein eigenes Format
  // SCL-90-S: {gs, gsi, pst, psdi, gsiT, pstT, psdiT, isClinicalCase, clinicalReason, scales[]}
  // BDI-II:   {totalScore, severity, subscales[]}
  scores           Json

  // Gemeinsame Felder über alle Instrumente
  isClinicalCase   Boolean    @default(false)
  clinicalSummary  String?    // Kurzzusammenfassung in Klartext

  createdAt        DateTime   @default(now())
}

// ─── Verlaufsnotizen (§16a Psychotherapiegesetz) ─────────────────────────────

model SessionNote {
  id          String    @id @default(cuid())
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id])
  authorId    String
  author      User      @relation("NoteAuthor", fields: [authorId], references: [id])

  date        DateTime  // Datum der Sitzung
  noteType    NoteType  @default(PROGRESS)
  content     String    // Inhalt (Freitext, §16a konform)

  // Soft-delete (Löschung protokollieren, aber 10 Jahre aufbewahren)
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([patientId])
  @@index([authorId])
  @@index([date])
}

// ─── Normtabellen ────────────────────────────────────────────────────────────

model NormTable {
  id          String         @id @default(cuid())
  name        String
  population  NormPopulation
  gender      String?
  ageMin      Int?
  ageMax      Int?
  sampleSize  Int?
  source      String?
  values      Json
  isDefault   Boolean        @default(false)
  createdAt   DateTime       @default(now())

  assessments Assessment[]
}

// ─── Audit-Log (DSGVO Art. 30) ───────────────────────────────────────────────

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  patientId    String?
  patient      Patient?    @relation(fields: [patientId], references: [id])
  assessmentId String?
  assessment   Assessment? @relation(fields: [assessmentId], references: [id])
  action       AuditAction
  ipAddress    String?
  userAgent    String?
  details      Json?
  createdAt    DateTime    @default(now())

  @@index([userId])
  @@index([patientId])
  @@index([assessmentId])
  @@index([createdAt])
}

// ─── Praxis-Branding (Admin konfigurierbar) ───────────────────────────────────

model PraxisConfig {
  id              String   @id @default(cuid())
  key             String   @unique  // z.B. "default" – erweiterbar für Multi-Tenant

  // Branding
  praxisName      String   @default("Meine Praxis")
  slogan          String?  // z.B. "Psychotherapeutische Praxis"
  logoBase64      String?  // Base64-encoded Logo (PNG/SVG)
  logoMimeType    String?  // "image/png" oder "image/svg+xml"

  // Farben (Hex)
  colorPrimary    String   @default("#4f46e5")   // Indigo
  colorPrimaryLight String @default("#eef2ff")   // Helles Indigo für Hover/Bg
  colorAccent     String   @default("#4338ca")   // Dunkleres Indigo für Hover
  colorSidebarText String  @default("#475569")   // Sidebar Schriftfarbe

  // Footer / Impressum
  imprintHtml     String?  // HTML für Impressum/Über
  contactEmail    String?
  contactPhone    String?
  address         String?

  // Bankverbindung (für Rechnungen, Honorarnoten)
  iban            String?
  bic             String?
  bankName        String?
  taxNumber       String?   // Steuernummer
  vatId           String?   // UID-Nummer

  // Praxis-Modus
  practiceMode    String   @default("single")   // "single" | "group"
  // Admin-Berechtigungen in Gruppenpraxis (JSON)
  // { seeCalendar: bool, seePatients: bool, seeProtocols: bool, seeDiagnoses: bool, seeFinance: bool, calendarAnonymized: bool }
  adminPermissions String?

  bundesland      String   @default("Kärnten")  // für Schulferien
  anamnesisTemplate String? // JSON: [{title, prefilledText}]

  // BMD-Export Kontozuordnung (JSON, vor erster Nutzung mit Steuerberater abstimmen!)
  // { erlosUstBefreit, erlosUstPflichtig, expenseAccounts: { [ExpenseCategory]: string } }
  bmdSettings     String?

  // Mahnwesen: Fristen in Tagen zwischen den Stufen (JSON)
  // { erinnerungDays, mahnung1Days, mahnung2Days }
  dunningSettings String?

  updatedAt       DateTime @updatedAt
  updatedBy       String?
}

// ─── Terminplanung ────────────────────────────────────────────────────────────

enum AppointmentStatus {
  PENDING     // Patient hat Anfrage gestellt
  CONFIRMED   // Therapeut hat bestätigt (oder direkt vom Therapeuten angelegt)
  CANCELLED   // Abgesagt
  NO_SHOW     // Patient nicht erschienen
  COMPLETED   // Stattgefunden
}

enum RecurrenceFreq {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum AbsenceReason {
  HOLIDAY
  SICK
  TRAINING
  OTHER
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum WaitlistStatus {
  WAITING
  OFFERED    // Slot wurde angeboten
  ACCEPTED
  EXPIRED
}

// Termintypen (konfigurierbar im Admin)
model AppointmentType {
  id           String   @id @default(cuid())
  name         String
  color        String   @default("#166534")
  durationMin  Int      @default(50)
  description  String?
  isActive     Boolean  @default(true)
  isBlocker    Boolean  @default(false)  // kein Patientenbezug (Supervision etc.)
  therapistId  String?  // null = praxisweit, sonst nur für diesen Therapeuten
  therapist    User?    @relation("TherapistAppointmentTypes", fields: [therapistId], references: [id])
  appointments Appointment[]
  createdAt    DateTime @default(now())

  @@index([therapistId])
}

// Wiederkehrende Regel (Terminserie)
model RecurringRule {
  id           String          @id @default(cuid())
  freq         RecurrenceFreq  @default(WEEKLY)
  dayOfWeek    Int             // 0=Mo, 1=Di, ..., 6=So
  startTime    String          // "10:00"
  count        Int?            // Anzahl Termine (optional)
  until        DateTime?       // Enddatum (optional)
  createdAt    DateTime        @default(now())
  appointments Appointment[]
}

// Einzeltermin
model Appointment {
  id              String            @id @default(cuid())
  patientId       String?           // null = Blocker ohne Patient
  patient         Patient?          @relation(fields: [patientId], references: [id])
  therapistId     String
  therapist       User              @relation("TherapistAppointments", fields: [therapistId], references: [id])
  typeId          String
  type            AppointmentType   @relation(fields: [typeId], references: [id])
  recurrenceId    String?
  recurrence      RecurringRule?    @relation(fields: [recurrenceId], references: [id])

  startAt         DateTime
  endAt           DateTime
  status          AppointmentStatus @default(PENDING)
  isBlocker       Boolean           @default(false)  // Blocker ohne Patient
  blockerNote     String?           // z.B. "Supervision", "Verwaltung"

  // Notizen
  patientNote     String?   // Wunsch/Grund vom Patienten
  therapistNote   String?   // Interne Notiz (nicht sichtbar für Patient)

  // Stornierung
  cancelledAt     DateTime?
  cancelledBy     String?   // userId
  cancelReason    String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  notifications   Notification[]
  waitlistEntries WaitlistEntry[]
  therapySession  TherapySession?  @relation("AppointmentSession")
  videoCall       VideoCall?       @relation("AppointmentVideoCall")

  @@index([therapistId])
  @@index([patientId])
  @@index([startAt])
  @@index([status])
}

// Verfügbarkeitsslots (wann ist der Therapeut buchbar)
model AvailabilitySlot {
  id          String    @id @default(cuid())
  therapistId String
  therapist   User      @relation("TherapistAvailability", fields: [therapistId], references: [id])
  dayOfWeek   Int       // 0=Mo … 6=So
  startTime   String    // "09:00"
  endTime     String    // "17:00"
  validFrom   DateTime?
  validUntil  DateTime?
  createdAt   DateTime  @default(now())

  @@index([therapistId])
}

// Abwesenheiten / Urlaub
model Absence {
  id          String        @id @default(cuid())
  therapistId String
  therapist   User          @relation("TherapistAbsences", fields: [therapistId], references: [id])
  startAt     DateTime
  endAt       DateTime
  reason      AbsenceReason @default(OTHER)
  note        String?
  createdAt   DateTime      @default(now())

  @@index([therapistId])
  @@index([startAt])
}

// Warteliste
model WaitlistEntry {
  id            String        @id @default(cuid())
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id])
  therapistId   String
  therapist     User          @relation("TherapistWaitlist", fields: [therapistId], references: [id])
  typeId        String?
  preferredDays Json          @default("[]")   // [0,2,4] = Mo,Mi,Fr
  preferredTime String?       // "morning" / "afternoon" / "any"
  status        WaitlistStatus @default(WAITING)
  offeredApptId String?
  offeredAt     DateTime?
  offeredAppt   Appointment?  @relation(fields: [offeredApptId], references: [id])
  note          String?
  createdAt     DateTime      @default(now())

  @@index([therapistId])
  @@index([patientId])
}

// Benachrichtigungen (E-Mail, SMS, In-App)
model Notification {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation("UserNotifications", fields: [userId], references: [id])
  appointmentId String?
  appointment   Appointment?       @relation(fields: [appointmentId], references: [id])
  channel       NotificationChannel
  status        NotificationStatus @default(PENDING)
  subject       String?
  body          String
  sentAt        DateTime?
  readAt        DateTime?
  scheduledFor  DateTime?          // für Erinnerungen im Voraus
  createdAt     DateTime           @default(now())

  @@index([userId])
  @@index([appointmentId])
  @@index([scheduledFor])
  @@index([status])
}

// Notification-Einstellungen pro User
model NotificationSetting {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id])
  emailEnabled    Boolean @default(true)
  smsEnabled      Boolean @default(false)
  inAppEnabled    Boolean @default(true)
  reminderHours   Int[]   @default([24, 1])   // Erinnerung X Stunden vorher
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Patientenfoto ───────────────────────────────────────────────────────────

model PatientPhoto {
  id          String   @id @default(cuid())
  patientId   String   @unique
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  data        Bytes    // binary image data
  mimeType    String   // "image/jpeg", "image/png"
  uploadedAt  DateTime @default(now())
  uploadedBy  String   // userId
}

// ─── Patientendokumente ──────────────────────────────────────────────────────

enum DocumentCategory {
  REFERRAL        // Zuweisung
  REPORT          // Befund
  CERTIFICATE     // Attest
  THERAPY_REPORT  // Therapiebericht
  INSURANCE       // Versicherungsdokument
  CONSENT         // Einverständniserklärung
  OTHER           // Sonstiges
}

model PatientDocument {
  id          String           @id @default(cuid())
  patientId   String
  patient     Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sessionId   String?          // optional: verknüpft mit TherapySession
  uploadedBy  String           // userId
  category    DocumentCategory @default(OTHER)
  name        String           // Dateiname / Bezeichnung
  mimeType    String
  size        Int              // Bytes
  data        Bytes            // binary file data
  note        String?          // optionale Bemerkung
  visibility  String           @default("therapist") // "therapist" | "all"
  uploadedAt  DateTime         @default(now())
  deletedAt   DateTime?        // soft-delete

  @@index([patientId])
  @@index([category])
  @@index([sessionId])
}

// Unveränderliches Archiv für ausgestellte Patientenberichte (Therapiebericht/
// Arztbrief/Verlaufsbericht). Wird beim Klick auf "Drucken / PDF" angelegt -
// die "Vorschau" erzeugt bewusst KEINEN Archiv-Eintrag, da sie noch ein
// Entwurf ist. Einmal archiviert, ändert sich der Inhalt nie wieder, auch wenn
// sich Branding/Steuernummer/Vorlage später ändern.
model PatientReportDocument {
  id              String    @id @default(cuid())
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reportType      String    // therapiebericht | arztbrief | verlaufsbericht
  createdByUserId String
  data            Bytes     // gerendertes HTML, eingefroren zum Ausstellungszeitpunkt
  mimeType        String    @default("text/html")
  anonymized      Boolean   @default(false)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([patientId])
}

// ─── Therapieplan & Ziele ────────────────────────────────────────────────────

enum TherapyGoalStatus {
  OPEN
  IN_PROGRESS
  ACHIEVED
  ABANDONED
}

model TherapyGoal {
  id          String            @id @default(cuid())
  patientId   String
  patient     Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy   String            // userId
  title       String
  description String?
  status      TherapyGoalStatus @default(OPEN)
  priority    Int               @default(1)  // 1=hoch, 2=mittel, 3=niedrig
  targetDate  DateTime?
  achievedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([patientId])
}

// ─── Diagnosen (ICD-10) ──────────────────────────────────────────────────────

enum DiagnosisType {
  PRIMARY     // Hauptdiagnose
  SECONDARY   // Nebendiagnose
  EXCLUSION   // Ausschlussdiagnose
}

model PatientDiagnosis {
  id          String        @id @default(cuid())
  patientId   String
  patient     Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdBy   String        // userId
  icdCode     String        // z.B. "F32.1"
  icdLabel    String        // z.B. "Mittelgradige depressive Episode"
  diagnosisType DiagnosisType @default(PRIMARY)
  certainty   String?       // "gesichert", "Verdacht", "Ausschluss"
  note        String?
  diagnosedAt DateTime      @default(now())
  createdAt   DateTime      @default(now())

  @@index([patientId])
  @@index([icdCode])
}

// ─── Finanzen ────────────────────────────────────────────────────────────────

enum TransactionType {
  INCOME      // Einnahme
  EXPENSE     // Ausgabe
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

enum PaymentStatus {
  PENDING     // Noch nicht bezahlt
  PAID        // Bezahlt
  OVERDUE     // Überfällig
  CANCELLED   // Storniert
}

enum IncomeCategory {
  HONORAR           // Honorare (Therapiesitzungen)
  OTHER_INCOME      // Sonstige Einnahmen
}

enum ExpenseCategory {
  MISC_BUSINESS     // Sonstiger betr. Aufwand
  GENERAL           // Allg. Ausgabe
  SESSION_TRANS     // Sessiontransaktion
  CANCELLATION      // Storno
  CONTINUING_ED     // Fortbildung
  THERAPY_TRAINING  // Lehrtherapie
  TRAVEL            // Reisekosten
  OFFICE            // Büroartikel
  MARKETING         // Werbung
  LITERATURE        // Literatur
  FEES_TAXES        // Gebühren und Abgaben
  SVA               // SVA
  RENT              // Miete
  INSURANCE         // Versicherung
  CAR               // Aufwand PKW
  OPERATIONS        // Betriebskosten
  ELECTRICITY       // Strom
  PHONE_INTERNET    // Telefon/Internet
  CLEANING          // Reinigung/Verbrauchsmaterial
  PERSONNEL         // Personal
  SUPERVISION       // Supervision
  DAILY_ALLOWANCE   // Taggeld
  ACCOMMODATION     // Nächtigungsgeld
  MILEAGE           // Kilometergeld
  DECOR             // Deko
}

model FinanceTransaction {
  id            String          @id @default(cuid())
  createdBy     String          // userId (Therapeut/Admin)
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  date          DateTime        // Bezahldatum
  createdAt     DateTime        @default(now())  // Erstellungsdatum
  description   String?
  paymentMethod PaymentMethod   @default(BANK_TRANSFER)
  paymentStatus PaymentStatus   @default(PAID)

  // Kategorie — entweder income oder expense, nicht beide
  incomeCategory  IncomeCategory?
  expenseCategory ExpenseCategory?

  // Verknüpfungen (optional)
  patientId     String?
  patient       Patient?        @relation(fields: [patientId], references: [id])
  appointmentId String?         // Verknüpfung mit Termin

  note          String?
  invoiceNumber String?         // Belegnummer

  @@index([createdBy])
  @@index([date])
  @@index([type])
  @@index([patientId])
}

// ─── Fahrtenbuch ─────────────────────────────────────────────────────────────

enum TripPurpose {
  PATIENT_VISIT    // Hausbesuch
  TRAINING         // Fortbildung
  SUPERVISION      // Supervision
  OFFICE           // Büro/Verwaltung
  OTHER
}

model MileageLog {
  id          String      @id @default(cuid())
  createdBy   String      // userId
  date        DateTime
  departure   String      // Abfahrtsort
  destination String      // Zielort
  purpose     TripPurpose @default(OTHER)
  purposeNote String?     // Freitext-Beschreibung
  kilometers  Decimal     @db.Decimal(8, 2)
  returnTrip  Boolean     @default(false)   // Retour → Distanz wird verdoppelt
  ratePerKm   Decimal     @db.Decimal(5, 4) @default(0.42)  // österreichischer Kilometersatz
  totalAmount Decimal     @db.Decimal(10, 2)                // km × rate (× 2 wenn returnTrip)
  patientId   String?     // optional bei Hausbesuchen
  patient     Patient?    @relation(fields: [patientId], references: [id])
  createdAt   DateTime    @default(now())

  @@index([createdBy])
  @@index([date])
}


// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 1: NEUE KERN-MODELLE nach KDS-Spezifikation
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Session (Therapiestunde) ─────────────────────────────────────────────────
// Getrennt von Assessment/Screening!
// Eine Session = eine Therapiestunde mit einem Patienten
// Assessments (SCL-90-S etc.) sind separate Screening-Instrumente

model TherapySession {
  id                    String              @id @default(cuid())
  patientId             String
  patient               Patient             @relation("PatientSessions", fields: [patientId], references: [id])
  therapistId           String
  therapist             User                @relation("TherapistSessions", fields: [therapistId], references: [id])
  appointmentId         String?             @unique  // optional: aus Kalendertermin erstellt
  appointment           Appointment?        @relation("AppointmentSession", fields: [appointmentId], references: [id])

  // Identifikation
  name                  String              // auto: "CodeName-001 - 27.06.2026", editierbar
  sessionNumber         Int                 // laufende Nummer pro Patient
  referenceNumber       String?             // Referenznummer für Sessionkopf (z.B. "S-2026-001")
  codeName              String?             // anonymisierter Name aus Patientenprofil
  source                SessionSource       @default(MANUAL)

  // Zeitdaten
  sessionDate           DateTime
  startTime             DateTime?
  endTime               DateTime?
  durationMinutes       Int?

  // Abrechnung
  billingMode           String              @default("time") // "time" | "unit"
  unitCount             Decimal?            @db.Decimal(8, 2)
  unitLengthMinutes     Int?
  unitPriceNet          Decimal?            @db.Decimal(10, 2)
  hourlyRateNet         Decimal?            @db.Decimal(10, 2)
  calculatedPriceNet    Decimal?            @db.Decimal(10, 2)
  serviceLabel          String?             // Dienstleistungsbezeichnung für Rechnung
  excludedFromFinances  Boolean             @default(false)
  exclusionReason       String?

  // Abgeleiteter Status (wird berechnet, nicht manuell gesetzt)
  billingStatus         SessionBillingStatus @default(UNBILLED)

  // Protokoll
  protocols             SessionProtocol[]

  // Metadaten
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  // Relationen
  txAllocations         TxSessionAllocation[]
  attachments           SessionAttachment[]
  assessmentLinks       SessionAssessmentLink[]
  travelLogEntry        TravelLogEntry?
  audioRecordings       AudioRecording[]        @relation("SessionAudio")
  supervisionEntries    SupervisionEntry[]      @relation("SessionSupervision")
  ratings               SessionRating[]         @relation("SessionRatings")
  serviceLines          SessionServiceLine[]    @relation("SessionServiceLines")
  assessmentValues      SessionAssessmentValue[] @relation("SessionAssessmentValues")
  supervisionLinks      SupervisionSessionLink[] @relation("SupervisionSessionLinks")

  @@index([patientId])
  @@index([therapistId])
  @@index([sessionDate])
}

model SessionProtocol {
  id              String          @id @default(cuid())
  sessionId       String
  type            ProtocolType
  session         TherapySession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sections        SessionProtocolSection[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([sessionId, type])
}

model SessionProtocolSection {
  id          String          @id @default(cuid())
  protocolId  String
  protocol    SessionProtocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  title       String
  content     String          // Rich-Text als HTML/Markdown
  sortOrder   Int             @default(0)
}

model SessionAttachment {
  id          String    @id @default(cuid())
  sessionId   String
  session     TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fileName    String
  mimeType    String
  size        Int
  data        Bytes
  encrypted   Boolean   @default(false)
  uploadedAt  DateTime  @default(now())

  @@index([sessionId])
}

// Verknüpfung Session <-> Screening (SCL-90-S, PHQ-9, etc.)
model SessionAssessmentLink {
  id          String         @id @default(cuid())
  sessionId   String
  session     TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assessmentId String
  assessment  Assessment     @relation(fields: [assessmentId], references: [id])
  createdAt   DateTime       @default(now())

  @@unique([sessionId, assessmentId])
}

// ─── Fahrtenbuch (session-gebunden) ──────────────────────────────────────────

model TravelLogEntry {
  id                String          @id @default(cuid())
  patientId         String
  patient           Patient         @relation("PatientTravelLog", fields: [patientId], references: [id])
  sessionId         String?         @unique
  session           TherapySession? @relation(fields: [sessionId], references: [id])
  createdBy         String

  startLocation     String
  destination       String
  distanceKm        Decimal         @db.Decimal(8, 2)
  ratePerKm         Decimal         @db.Decimal(5, 4) @default(0.42)
  amountNet         Decimal         @db.Decimal(10, 2)
  billableToPatient Boolean         @default(false)
  purpose           String?
  date              DateTime

  createdAt         DateTime        @default(now())

  @@index([patientId])
  @@index([createdBy])
}

// ─── Referenznummern-Ledger ───────────────────────────────────────────────────

model ReferenceNumberLedger {
  id              String    @id @default(cuid())
  referenceNumber String    @unique
  sequenceNumber  Int
  referenceYear   Int
  direction       TxDirection
  transactionId   String?
  formatUsed      String
  releasedAt      DateTime?
  releaseReason   String?
  createdAt       DateTime  @default(now())

  @@index([referenceYear, direction])
}

// ─── Transaktion (führender buchhalterischer Datensatz) ──────────────────────

model Transaction {
  id                      String              @id @default(cuid())
  patientId               String?
  patient                 Patient?            @relation("PatientTransactions", fields: [patientId], references: [id])
  createdByUserId         String
  createdBy               User                @relation("UserTransactions", fields: [createdByUserId], references: [id])

  direction               TxDirection
  sourceType              TxSourceType        @default(MANUAL)
  referenceNumber         String              @unique
  transactionDate         DateTime

  // Zahler / Empfänger
  payerName               String
  payerAddress            String?
  payeeName               String
  payeeAddress            String?

  // Beträge
  amountNet               Decimal             @db.Decimal(10, 2)
  vatRate                 Decimal             @db.Decimal(5, 4) @default(0)
  vatAmount               Decimal             @db.Decimal(10, 2) @default(0)
  amountGross             Decimal             @db.Decimal(10, 2)

  // Zahlung
  paymentStatus           TxPaymentStatus     @default(UNPAID)
  paidAt                  DateTime?
  paymentMethod           TxPaymentMethod?
  paymentUndoDeadline     DateTime?           // paid_at + 5 Minuten

  // Lifecycle
  lifecycleStatus         TxLifecycleStatus   @default(ACTIVE)
  cancelledByTxId         String?             // zeigt auf Stornotransaktion
  cancelsTxId             String?             // zeigt auf stornierte Original-Tx

  // Sonstiges
  notes                   String?
  hellocashReceiptId      String?
  invoiceTemplateId       String?             // explizite Vorlagen-Wahl bei Erstellung (überschreibt Patient-Default)

  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  // Relationen
  lineItems               TxLineItem[]
  sessionAllocations      TxSessionAllocation[]
  invoiceDocuments        InvoiceDocument[]
  receipts                TransactionReceipt[]    @relation("TxReceipts")
  dunnings                Dunning[]

  @@index([patientId])
  @@index([transactionDate])
  @@index([lifecycleStatus])
}

model TxLineItem {
  id              String      @id @default(cuid())
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  sessionId       String?

  description     String
  serviceLabel    String?
  quantity        Decimal     @db.Decimal(8, 2) @default(1)
  unitPriceNet    Decimal     @db.Decimal(10, 2)
  amountNet       Decimal     @db.Decimal(10, 2)
  vatRate         Decimal     @db.Decimal(5, 4) @default(0)
  vatAmount       Decimal     @db.Decimal(10, 2) @default(0)
  amountGross     Decimal     @db.Decimal(10, 2)
  lineDate        DateTime?
  sortOrder       Int         @default(0)

  allocations     TxSessionAllocation[]

  @@index([transactionId])
}

model TxSessionAllocation {
  id                    String          @id @default(cuid())
  transactionId         String
  transaction           Transaction     @relation(fields: [transactionId], references: [id])
  lineItemId            String?
  lineItem              TxLineItem?     @relation(fields: [lineItemId], references: [id])
  sessionId             String
  session               TherapySession  @relation(fields: [sessionId], references: [id])

  allocationPercentage  Decimal         @db.Decimal(5, 4) @default(1.0)
  allocatedAmountNet    Decimal         @db.Decimal(10, 2)
  allocatedVatAmount    Decimal         @db.Decimal(10, 2) @default(0)
  allocatedAmountGross  Decimal         @db.Decimal(10, 2)

  isActive              Boolean         @default(true)
  deactivatedAt         DateTime?
  deactivationReason    String?
  createdAt             DateTime        @default(now())

  @@index([transactionId])
  @@index([sessionId])
}

// ─── Rechnungsdokument ────────────────────────────────────────────────────────

model InvoiceDocument {
  id                    String              @id @default(cuid())
  transactionId         String
  transaction           Transaction         @relation(fields: [transactionId], references: [id])
  documentType          InvoiceDocumentType @default(INVOICE_PDF)
  format                String              @default("pdf")  // pdf | xlsx | image
  anonymized            Boolean             @default(false)
  encryptedPdf          Boolean             @default(false)
  data                  Bytes?              // generiertes Dokument
  mimeType              String?
  sentAt                DateTime?
  markedSentAt          DateTime?
  deletedAt             DateTime?
  createdAt             DateTime            @default(now())

  @@index([transactionId])
}

// ─── Mahnwesen ───────────────────────────────────────────────────────────────
// Protokoll tatsaechlich versendeter Mahnungen. Vorschlaege selbst werden NICHT
// persistiert, sondern bei jedem Aufruf live aus Transaction + diesem Verlauf
// berechnet (src/lib/finance/dunningSuggestions.ts) - so bleibt der Stand immer
// aktuell (z.B. wenn zwischenzeitlich bezahlt wurde).
model Dunning {
  id            String       @id @default(cuid())
  transactionId String
  transaction   Transaction  @relation(fields: [transactionId], references: [id])
  level         DunningLevel
  sentAt        DateTime     @default(now())
  sentBy        String       // userId
  emailTo       String?      // null = nur PDF erzeugt/heruntergeladen, kein Mailversand
  pdf           Bytes        // unveraenderliches Archiv des tatsaechlich versendeten Schreibens
  pdfMime       String       @default("application/pdf")
  createdAt     DateTime     @default(now())

  @@index([transactionId])
}

// ─── TheraPsy-Migration ───────────────────────────────────────────────────────
// Protokolliert jeden ausgefuehrten Import-Lauf. Das source_hash-Feld
// verhindert, dass dieselbe Datei zweimal eingespielt wird.
model MigrationRun {
  id           String   @id @default(cuid())
  sourceApp    String   @default("TheraPsy")
  sourceHash   String   @unique  // SHA256 des hochgeladenen Exports
  runBy        String            // userId
  ranAt        DateTime @default(now())
  stats        String            // JSON: { patients, sessions, transactions, diagnoses, ... }
  warnings     String?           // JSON: array of warning strings
}

// ─── Rechnungsvorlage ─────────────────────────────────────────────────────────

model InvoiceTemplate {
  id              String    @id @default(cuid())
  name            String
  description     String?
  htmlContent     String    // HTML-Template mit {{platzhalter}}
  cssContent      String?   // optionales CSS
  isDefault       Boolean   @default(false)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // GUI-Felder
  invoiceTitle    String?   @default("Honorarnote")
  primaryColor    String?   @default("#4f46e5")
  paymentDays     Int       @default(14)
  iban            String?
  bic             String?
  bankName        String?
  taxNumber       String?   // Steuernummer
  vatId           String?   // UID-Nummer
  praxisName      String?
  praxisAddress   String?
  praxisPhone     String?
  praxisEmail     String?
  footerText      String?
  showQrCode      Boolean   @default(true)

  // Design-Elemente (Base64)
  headerImageBase64  String?   // Briefkopf-Banner
  headerImageMime    String?
  footerImageBase64  String?   // Brieffuß-Banner
  footerImageMime    String?
  bgImageBase64      String?   // Hintergrundbild / Briefpapier
  bgImageMime        String?
  bgImageOpacity     Float     @default(0.08)   // 0.0–1.0
  bgImageMode        String    @default("behind") // "behind" | "watermark"
  signatureImageBase64 String? // Unterschrift + Stempel, unten rechts
  signatureImageMime   String?

  // Wenn false: htmlContent wird ignoriert, App nutzt immer das aktuelle Code-Layout (DEFAULT_INVOICE_HTML)
  // Wenn true: Nutzer hat im HTML-Editor manuell editiert -> gespeicherter htmlContent bleibt dauerhaft erhalten
  customHtml      Boolean   @default(false)

  patients        Patient[] @relation("PatientInvoiceTemplate")
}

// ─── Transaktionstyp ─────────────────────────────────────────────────────────

model TxType {
  id          String      @id @default(cuid())
  name        String
  direction   String      // "income" | "expense" | "both"
  bmdCode     String?
  isSystemType Boolean    @default(false)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
}

// ─── Profile Timeline ─────────────────────────────────────────────────────────

model ProfileTimelineEvent {
  id                  String    @id @default(cuid())
  patientId           String
  patient             Patient   @relation("PatientTimeline", fields: [patientId], references: [id], onDelete: Cascade)
  eventType           String    // profile_created, session_created, diagnosis_added, etc.
  relatedEntityType   String?   // "session" | "transaction" | "diagnosis" | ...
  relatedEntityId     String?
  title               String
  summary             String?
  eventDate           DateTime
  createdByUserId     String?
  createdAt           DateTime  @default(now())

  @@index([patientId])
  @@index([eventDate])
}

// ─── Anamnese ────────────────────────────────────────────────────────────────

model Anamnesis {
  id          String              @id @default(cuid())
  patientId   String              @unique
  patient     Patient             @relation("PatientAnamnesis", fields: [patientId], references: [id], onDelete: Cascade)
  sections    AnamnesisSection[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model AnamnesisSection {
  id          String    @id @default(cuid())
  anamnesisId String
  anamnesis   Anamnesis @relation(fields: [anamnesisId], references: [id], onDelete: Cascade)
  title       String
  content     String?   // Rich-Text
  sortOrder   Int       @default(0)
}

// ─── Medikamente ─────────────────────────────────────────────────────────────

model Medication {
  id          String    @id @default(cuid())
  patientId   String
  patient     Patient   @relation("PatientMedications", fields: [patientId], references: [id], onDelete: Cascade)
  name        String
  source      String?
  note        String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([patientId])
}

// ─── Kontingent ──────────────────────────────────────────────────────────────

model ContingentAccount {
  id              String    @id @default(cuid())
  patientId       String
  patient         Patient   @relation("PatientContingents", fields: [patientId], references: [id], onDelete: Cascade)
  name            String
  initialUnits    Decimal   @db.Decimal(8, 2)
  remainingUnits  Decimal   @db.Decimal(8, 2)
  unitLabel       String    @default("sessions")  // sessions | hours | units
  validFrom       DateTime?
  validUntil      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([patientId])
}

// ─── Google Calendar ──────────────────────────────────────────────────────────

model GoogleCalendarConnection {
  id                    String            @id @default(cuid())
  userId                String            @unique
  user                  User              @relation("UserGoogleCalendar", fields: [userId], references: [id], onDelete: Cascade)
  googleAccountEmail    String
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  calendarId            String
  syncEnabled           Boolean           @default(true)
  syncStatus            GoogleSyncStatus  @default(ACTIVE)
  lastSyncAt            DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

// ─── Video-Calls (Jitsi) ─────────────────────────────────────────────────────

model VideoCall {
  id                String          @id @default(cuid())
  patientId         String?
  patient           Patient?        @relation("PatientVideoCalls", fields: [patientId], references: [id])
  appointmentId     String?         @unique
  appointment       Appointment?    @relation("AppointmentVideoCall", fields: [appointmentId], references: [id])
  sessionId         String?
  createdByUserId   String
  createdBy         User            @relation("UserVideoCalls", fields: [createdByUserId], references: [id])

  callCode          String          @unique   // zufälliger Code, anonym
  accessLink        String          // Jitsi-Link
  jitsiRoomName     String          @unique   // Raumname in Jitsi

  startsAt          DateTime?
  expiresAt         DateTime?
  status            VideoCallStatus @default(PLANNED)
  maxParticipants   Int?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([patientId])
}

// ─── Praxis-Standorte und Räume ──────────────────────────────────────────────

model PracticeLocation {
  id          String    @id @default(cuid())
  name        String
  addressLine1 String?
  addressLine2 String?
  postalCode  String?
  city        String?
  country     String    @default("AT")
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  rooms       Room[]
}

model Room {
  id          String            @id @default(cuid())
  locationId  String?
  location    PracticeLocation? @relation(fields: [locationId], references: [id])
  name        String
  color       String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
}

// ─── Export-Jobs ─────────────────────────────────────────────────────────────

model ExportJob {
  id                String    @id @default(cuid())
  createdByUserId   String
  createdBy         User      @relation("UserExportJobs", fields: [createdByUserId], references: [id])
  exportType        String    // session_invoices | finance_summary | bmd | protocols | etc.
  format            String    // pdf | csv | xlsx | zip
  profileScopeJson  String?   // optional: bestimmte Patienten
  dateFrom          DateTime?
  dateTo            DateTime?
  status            String    @default("pending")  // pending | processing | done | failed
  data              Bytes?    // generierter Export
  mimeType          String?
  warningAcknowledgedAt DateTime?
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  @@index([createdByUserId])
}

// ─── Audio-Aufnahmen (Sitzungen + Patientenebene) ─────────────────────────────

model AudioRecording {
  id          String          @id @default(cuid())
  // Entweder an eine Sitzung ODER direkt an einen Patienten geknüpft (oder beides)
  sessionId   String?
  session     TherapySession? @relation("SessionAudio", fields: [sessionId], references: [id], onDelete: Cascade)
  patientId   String?
  patient     Patient?        @relation("PatientAudio", fields: [patientId], references: [id], onDelete: Cascade)
  label       String?         // Benutzerfreundlicher Name, z.B. "Erstsitzung Notiz"
  fileName    String
  mimeType    String          @default("audio/webm")
  size        Int             // Bytes (original, unverschlüsselt)
  durationSec Int?
  data        Bytes           // AES-256-GCM verschlüsselt wenn encrypted=true
  encrypted   Boolean         @default(true)
  iv          String?         // Hex-kodierter IV für AES-GCM (nur wenn encrypted=true)
  source      String          @default("UPLOAD") // UPLOAD | BROWSER_RECORDING
  createdAt   DateTime        @default(now())
  createdBy   String

  @@index([sessionId])
  @@index([patientId])
}

// ─── Supervision ─────────────────────────────────────────────────────────────

model SupervisionEntry {
  id                  String         @id @default(cuid())
  superviseeId        String         // User (Therapeut in Ausbildung)
  supervisee          User           @relation("SuperviseeEntries", fields: [superviseeId], references: [id])
  supervisorId        String?        // User (Supervisor, optional)
  supervisor          User?          @relation("SupervisorEntries", fields: [supervisorId], references: [id])
  sessionId           String?        // verknüpfte Sitzung (legacy, single-session)
  session             TherapySession? @relation("SessionSupervision", fields: [sessionId], references: [id])

  // Spec-konforme Felder (KDS-SCR-08B)
  name                String?        // optionaler Bezeichner z.B. "Sv_1_02.05.2026"
  supervisorName      String?        // Freitext-Name des Supervisors (wenn kein User)
  groupParticipants   String?        // Komma-getrennte Namen der Gruppe
  unitCount           Decimal?       @db.Decimal(8, 2)  // z.B. 0.5, 1, 2

  date                DateTime
  durationMinutes     Int
  supervisionType     String         @default("INDIVIDUAL") // INDIVIDUAL | GROUP | SELF
  content             String?        // Inhalt / Notizen
  fachspezifikum      Boolean        @default(false)
  approved            Boolean        @default(false)
  approvedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Verknüpfte Sessions (many-to-many via Link-Tabelle)
  sessionLinks        SupervisionSessionLink[] @relation("SupervisionLinks")

  @@index([superviseeId])
  @@index([date])
}

// ─── Patientenbewertungen / Verlaufsstatistik ────────────────────────────────

model SessionRating {
  id                  String         @id @default(cuid())
  sessionId           String
  session             TherapySession @relation("SessionRatings", fields: [sessionId], references: [id], onDelete: Cascade)
  patientId           String
  patient             Patient        @relation("PatientRatings", fields: [patientId], references: [id])
  ratingDate          DateTime
  // Skalen 1-10
  wellbeing           Int?           // Wohlbefinden
  anxiety             Int?           // Angst (invertiert)
  depression          Int?           // Depressivität (invertiert)
  sessionSatisfaction Int?           // Zufriedenheit mit Sitzung
  goalProgress        Int?           // Fortschritt Therapieziele
  customValues        String?        // JSON für eigene Skalen
  note                String?
  createdAt           DateTime       @default(now())

  @@index([patientId])
  @@index([sessionId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 2: SESSION-VORLAGEN, LEISTUNGEN & BEWERTUNGEN (KDS-Spec v2.0)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Session-Vorlage ─────────────────────────────────────────────────────────
// Definiert, welche Protokollvorlage + Leistungsvorlage eine Session-Art hat

model SessionTemplate {
  id                      String    @id @default(cuid())
  name                    String    // z.B. "Standardsession", "Erstgespräch"
  isDefault               Boolean   @default(false)
  shortProtocolTemplateId String?
  shortProtocolTemplate   ProtocolTemplate? @relation("ShortTemplate", fields: [shortProtocolTemplateId], references: [id])
  longProtocolTemplateId  String?
  longProtocolTemplate    ProtocolTemplate? @relation("LongTemplate", fields: [longProtocolTemplateId], references: [id])
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

// ─── Protokollvorlage ────────────────────────────────────────────────────────
// Definiert die konfigurierbaren Felder eines Protokolls

model ProtocolTemplate {
  id           String                @id @default(cuid())
  templateType String                // "SHORT" | "LONG"
  name         String
  version      Int                   @default(1)
  isActive     Boolean               @default(true)
  fields       ProtocolTemplateField[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  shortForTemplates SessionTemplate[] @relation("ShortTemplate")
  longForTemplates  SessionTemplate[] @relation("LongTemplate")
}

// ─── Protokollvorlagen-Feld ──────────────────────────────────────────────────

model ProtocolTemplateField {
  id             String           @id @default(cuid())
  templateId     String
  template       ProtocolTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label          String           // Überschrift (z.B. "Thema der Stunde")
  prefilledText  String?          // Vorausgefüllter Text
  sortOrder      Int              @default(0)
  required       Boolean          @default(false)
  exportable     Boolean          @default(true)
  visible        Boolean          @default(true)
  // Breite im Grid: "full" | "half" | "third"
  widthMode      String           @default("full")
  heightMode     String           @default("medium") // "small" | "medium" | "large"

  @@index([templateId])
}

// ─── Session-Leistungszeile ──────────────────────────────────────────────────
// Zusatzleistungen pro Session (Diagnose, Testverfahren, eigene Positionen)

model SessionServiceLine {
  id              String         @id @default(cuid())
  sessionId       String
  session         TherapySession @relation("SessionServiceLines", fields: [sessionId], references: [id], onDelete: Cascade)
  description     String
  quantity        Decimal        @db.Decimal(8, 2) @default(1)
  unitPriceNet    Decimal        @db.Decimal(10, 2)
  vatRate         Decimal        @db.Decimal(5, 4) @default(0)
  amountNet       Decimal        @db.Decimal(10, 2)
  amountGross     Decimal        @db.Decimal(10, 2)
  sortOrder       Int            @default(0)
  category        String?        // "diagnose" | "testverfahren" | "zusatzleistung" | "freitext"
  catalogCode     String?        // GOÄ/GebüH-Code wenn vorhanden
  createdAt       DateTime       @default(now())

  @@index([sessionId])
}

// ─── Sitzungsbewertung (spec-konform: Motivation, Pünktlichkeit, Lebensfreude) 
// Ersetzt/ergänzt SessionRating mit den 3 Spec-Feldern

model SessionAssessmentValue {
  id             String         @id @default(cuid())
  sessionId      String
  session        TherapySession @relation("SessionAssessmentValues", fields: [sessionId], references: [id], onDelete: Cascade)
  assessmentName String         // "motivation" | "punctuality" | "joie_de_vivre" | custom
  value          Int?           // 0-10
  scaleMin       Int            @default(0)
  scaleMax       Int            @default(10)
  createdAt      DateTime       @default(now())

  @@unique([sessionId, assessmentName])
  @@index([sessionId])
}

// ─── MileageLog: returnTrip Feld ─────────────────────────────────────────────
// Hinweis: returnTrip wird direkt zu MileageLog hinzugefügt (siehe Migration)
// Hier das separate TravelLog für Sessions (bereits vorhanden als TravelLogEntry)
// returnTrip wird via ALTER TABLE hinzugefügt

// ─── Supervisions-Session-Verknüpfung ───────────────────────────────────────

model SupervisionSessionLink {
  id                          String          @id @default(cuid())
  supervisionEntryId          String
  supervisionEntry            SupervisionEntry @relation("SupervisionLinks", fields: [supervisionEntryId], references: [id], onDelete: Cascade)
  sessionId                   String
  session                     TherapySession  @relation("SupervisionSessionLinks", fields: [sessionId], references: [id])
  profileId                   String
  clientDisplayNameSnapshot   String?         // anonymisierter Name zum Zeitpunkt der Supervision
  createdAt                   DateTime        @default(now())

  @@unique([supervisionEntryId, sessionId])
  @@index([supervisionEntryId])
  @@index([sessionId])
}

// ─── Transaktionsbeleg ───────────────────────────────────────────────────────

model TransactionReceipt {
  id            String   @id @default(cuid())
  transactionId String
  transaction   Transaction @relation("TxReceipts", fields: [transactionId], references: [id], onDelete: Cascade)
  fileId        String?
  receiptType   String   @default("external_voucher") // "external_voucher" | "manual"
  fileName      String?
  mimeType      String?
  size          Int?
  data          Bytes?
  createdAt     DateTime @default(now())
  deletedAt     DateTime?

  @@index([transactionId])
}


// ═══════════════════════════════════════════════════════════════════════════════
// PHASE 3: Offene Punkte aus Gap-Report (12 Items)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── BackupJob ───────────────────────────────────────────────────────────────

model BackupJob {
  id            String   @id @default(cuid())
  tenantId      String?
  jobType       String   @default("manual")   // "manual" | "automatic"
  status        String   @default("pending")  // "pending" | "running" | "done" | "failed"
  targetPath    String?
  sourceFileId  String?
  encrypted     Boolean  @default(false)
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  errorMessage  String?
  createdBy     String?

  @@index([status])
  @@index([startedAt])
}

// ─── UserVisualSettings ──────────────────────────────────────────────────────

model UserVisualSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  theme           String   @default("light")
  fontSize        String   @default("medium")
  accentColor     String   @default("#4f46e5")
  fontFamily      String   @default("original")
  helpToolEnabled Boolean  @default(true)
  classicMode     Boolean  @default(false)
  backgroundImageId String?
  updatedAt       DateTime @updatedAt
}

// ─── UsageTelemetryConsent ───────────────────────────────────────────────────

model UsageTelemetryConsent {
  id          String   @id @default(cuid())
  userId      String   @unique
  enabled     Boolean  @default(false)
  consentedAt DateTime?
  revokedAt   DateTime?
  version     String   @default("1.0")
  source      String   @default("settings")
}


model SmtpConfig {
  id            String   @id @default(cuid())
  provider      String   @default("custom")  // gmail | office365 | custom
  host          String
  port          Int      @default(587)
  secure        Boolean  @default(false)     // true = TLS/SSL (Port 465)
  user          String
  password      String                       // verschlüsselt gespeichert
  fromName      String   @default("KDS Praxis")
  fromEmail     String
  replyTo       String?
  isActive      Boolean  @default(true)
  lastTestedAt  DateTime?
  lastTestOk    Boolean?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ReportTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  reportType      String   // therapiebericht | arztbrief | verlaufsbericht | all
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  htmlContent     String   // HTML-Template mit {{platzhalter}}

  // GUI-Felder
  primaryColor    String?  @default("#1a1a2e")
  fontFamily      String?  @default("Times New Roman, serif")
  fontSize        String?  @default("11pt")
  praxisName      String?
  praxisAddress   String?
  praxisPhone     String?
  praxisEmail     String?
  taxNumber       String?
  vatId           String?
  footerText      String?
  showPageNumbers Boolean  @default(true)
  showDataProtection Boolean @default(true)

  // Grafik-Elemente (Base64)
  headerImageBase64  String?
  headerImageMime    String?
  footerImageBase64  String?
  footerImageMime    String?
  bgImageBase64      String?
  bgImageMime        String?
  bgImageOpacity     Float   @default(0.06)
  bgImageMode        String  @default("behind")
  signatureImageBase64 String? // Unterschrift + Stempel, unten rechts
  signatureImageMime   String?

  // Wenn false: htmlContent wird ignoriert, App nutzt immer das aktuelle Code-Layout (DEFAULT_REPORT_HTML)
  // Wenn true: Nutzer hat im HTML-Editor manuell editiert -> gespeicherter htmlContent bleibt dauerhaft erhalten
  customHtml      Boolean @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Bestätigungsvorlage ────────────────────────────────────────────────────
// Eigenständiges, paralleles Vorlagensystem (gleiche Architektur wie
// InvoiceTemplate/ReportTemplate) für Patientenbestätigungen
// (Terminbestätigung, Anwesenheitsbestätigung, etc.)

model ConfirmationTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  templateKey     String?  // Kennung für mitgelieferte Standard-Vorlagen, z.B. "terminbestaetigung"
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  htmlContent     String   // Seiten-Layout mit {{platzhalter}}, enthält {{freitext}} als Inhalts-Slot
  bodyText        String   @default("") // Vorgabetext mit Platzhaltern, wird beim Erstellen ins Freitext-Feld kopiert

  // GUI-Felder (Branding) - identisch zu Rechnungs-/Berichtsvorlage
  primaryColor    String?  @default("#4f46e5")
  fontFamily      String?  @default("Helvetica Neue, Arial, sans-serif")
  fontSize        String?  @default("11pt")
  praxisName      String?
  praxisAddress   String?
  praxisPhone     String?
  praxisEmail     String?
  taxNumber       String?
  vatId           String?
  footerText      String?

  // Design-Elemente (Base64)
  headerImageBase64  String?
  headerImageMime    String?
  footerImageBase64  String?
  footerImageMime    String?
  bgImageBase64      String?
  bgImageMime        String?
  bgImageOpacity     Float    @default(0.06)
  bgImageMode        String   @default("behind")
  signatureImageBase64 String? // Unterschrift + Stempel, unten rechts
  signatureImageMime   String?

  // Wenn false: htmlContent wird ignoriert, App nutzt immer das aktuelle Code-Layout (DEFAULT_CONFIRMATION_HTML)
  customHtml      Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  confirmations   Confirmation[]
}

enum ConfirmationStatus {
  ENTWURF
  AUSGESTELLT
}

model Confirmation {
  id              String               @id @default(cuid())
  patientId       String
  patient         Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sessionId       String?              // optional: verknüpft mit TherapySession (lose Referenz, keine FK)
  templateId      String?
  template        ConfirmationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  titel           String
  inhalt          String               // Freitext (kann noch unaufgelöste {{platzhalter}} enthalten)
  bemerkungen     String?
  datum           DateTime             @default(now())
  status          ConfirmationStatus   @default(ENTWURF)
  createdByUserId String
  deletedAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  documents       ConfirmationDocument[]

  @@index([patientId])
}

// Unveränderliches Archiv für ausgestellte Bestätigungen - gleiches Prinzip
// wie InvoiceDocument/PatientReportDocument: einmal als PDF/Druck erzeugt,
// bleibt der Inhalt für immer eingefroren, unabhängig von späteren
// Branding-/Vorlagen-Änderungen.
model ConfirmationDocument {
  id              String       @id @default(cuid())
  confirmationId  String
  confirmation    Confirmation @relation(fields: [confirmationId], references: [id], onDelete: Cascade)
  data            Bytes
  mimeType        String       @default("text/html")
  deletedAt       DateTime?
  createdAt       DateTime     @default(now())

  @@index([confirmationId])
}

model PatientShare {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation("PatientShares", fields: [patientId], references: [id])
  ownerId       String   // Therapeut dem der Patient gehört
  sharedWithId  String   // Therapeut dem Zugriff gewährt wird
  sharedWith    User     @relation("SharedWithUser", fields: [sharedWithId], references: [id])
  owner         User     @relation("OwnerUser", fields: [ownerId], references: [id])
  canEdit       Boolean  @default(false)  // false = nur lesen
  createdAt     DateTime @default(now())

  @@unique([patientId, sharedWithId])
}
